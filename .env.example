# Copy to .env and fill in real values. Never commit the real .env.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
FAL_KEY=your-fal-api-key

# Public origin of THIS backend — used to build every media URL it returns
# (uploads, songs, montage output) and to detect which incoming URLs are local
# files. Dev: your machine's LAN IP. Prod: your HTTPS domain, e.g.
# https://api.yourdomain.com  (must match the app's --dart-define=API_BASE_URL host).
PUBLIC_BASE_URL=http://192.168.1.169:8000
